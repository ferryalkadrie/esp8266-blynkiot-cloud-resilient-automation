// ====================================================================
// NETWORK MANAGEMENT & HARDWARE WATCHDOG
// ====================================================================

void connectToWiFi() {
  WiFi.begin(ssid1, pass1);
  Serial.print("Connecting to Primary SSID: " + String(ssid1));
  unsigned long start = millis();
  while (WiFi.status() != WL_CONNECTED && millis() - start < 10000) {
    delay(200);
    Serial.print(".");
  }

  if (WiFi.status() != WL_CONNECTED) {
    WiFi.begin(ssid2, pass2);
    Serial.print("\nPrimary Failed. Switching to Backup SSID: " + String(ssid2));
    start = millis();
    while (WiFi.status() != WL_CONNECTED && millis() - start < 10000) {
      delay(200);
      Serial.print(".");
    }
  }

  if (WiFi.status() == WL_CONNECTED) {
    Serial.println("\n✅ WiFi Connected. IP: " + WiFi.localIP().toString());
    configTime(0, 0, "pool.ntp.org");
    delay(500);
  } else {
    Serial.println("\n❌ Network connection failed entirely.");
  }
}

void watchdogResetIfHang() {
  static unsigned long lastAlive = millis();
  static unsigned long lastCheck = millis();

  if (Blynk.connected() || WiFi.status() == WL_CONNECTED) {
    lastAlive = millis();
  }
  
  if (millis() - lastCheck > 10000) { 
    lastCheck = millis();
    if (millis() - lastAlive > 60000) { 
      Serial.println("⚠ System unresponsive > 60s. Activating software-level hardware reset...");
      delay(500); 
      ESP.restart();
    }
  }
}

// ====================================================================
// ARDUINO CORE SETUP & EXECUTION LOOP
// ====================================================================

void setup() {
  Serial.begin(115200);
  Serial.println("Initializing Multichannel Smart Automation System...");
  
  for (int i = 0; i < relayCount; i++){
    pinMode(relays[i], OUTPUT);
    digitalWrite(relays[i], HIGH); // Keep all relays safely disconnected on boot
  }
  
  connectToWiFi();

  // Non-blocking Blynk cloud handshaking initialization (Blynk IoT Server v2)
  Blynk.config(auth, "blynk.cloud", 80);
  Blynk.connect(5000); 
  rtc.begin();

  if (Blynk.connected()) {
    restoreFromThingSpeak();
    restored = true;
  } else {
    Serial.println("Blynk cloud unreachable on initialization. Queued for runtime recovery.");
    restored = false;
  }

  lastSendTS = millis();
}

void loop() {
  if (Blynk.connected()) Blynk.run();
  
  // Periodic backup engine (1 hour intervals)
  if (millis() - lastSendTS >= sendInterval) {
    lastSendTS = millis();
    sendToThingSpeak();
    needsThingSpeakUpdate = false; 
  }
  
  // Event-driven state sync engine (Debounced under 5s limits)
  if (needsThingSpeakUpdate && millis() - lastButtonActionMillis >= minSendInterval) {
    lastButtonActionMillis = millis();
    sendToThingSpeak(); 
    needsThingSpeakUpdate = false;
  }

  // Network self-healing monitor (Checks every 5 minutes)
  if (millis() - previousCheckMillis >= checkInterval) {
    previousCheckMillis = millis();
    if (!Blynk.connected()) {
      Serial.println("Connection dropped. Executing automated network recovery...");
      connectToWiFi();
      Blynk.config(auth, "blynk.cloud", 80);
      Blynk.connect(5000); 
      restored = false;
    } 
    
    if (Blynk.connected() && !restored) {
      restoreFromThingSpeak();
      restored = true;
    }
  }

  watchdogResetIfHang(); 
  delay(100);
}
